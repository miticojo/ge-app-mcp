# ==============================================================================
# Gemini Enterprise MCP Server - Environment Configuration Template
# ==============================================================================
# Copy this file to '.env' in the project root and replace placeholders with
# your actual Google Cloud Project configurations.
# ==============================================================================

# 🌐 1. Google Cloud Core Configurations
GCP_PROJECT=your-gcp-project-id
GCP_LOCATION=global                 # Optional. Defaults to "global" (supports "us", "eu", etc.)
GCP_COLLECTION=default_collection   # Optional. Defaults to "default_collection"

# 🔒 2. Quota & Billing Project Configuration
# Highly recommended if your Application Default Credentials (ADC) use a different 
# sandbox project for billing. This attributes costs and quotas to your target project.
GOOGLE_CLOUD_QUOTA_PROJECT=your-gcp-project-id

# 🛡️ 3. Security Scopes (Least Privilege Gatekeeper)
# Comma-separated list of allowed operational scopes: search, admin, billing.
#   - Use 'search' for read-only user-facing RAG applications.
#   - Use 'search,admin' for SRE/DevOps automation or content indexing.
#   - Defaults to 'search,admin,billing' if omitted.
MCP_SCOPES=search,admin,billing
